{
  "manifest_version": 3,
  "name": "Helpdesk Assistant",
  "version": "0.0.1",
  "description": "AI moderator assistant for Phitron helpdesk.",
  "action": {
    "default_title": "Open Helpdesk Assistant"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "tabs",
    "activeTab",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "side_panel": {
    "default_path": "index.html"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/index.tsx-FJGbvvfU.js"
      ],
      "matches": [
        "https://helpdesk.phitron.io/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "admin.html"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "https://helpdesk.phitron.io/*"
      ],
      "resources": [
        "assets/index.tsx-FJGbvvfU.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
